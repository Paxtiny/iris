{
  "manifest_version": 3,
  "name": "nicodAImus iris",
  "version": "0.1.0",
  "description": "Privacy-first email phishing detection. Scores emails 0-10 for phishing risk, entirely in your browser.",
  "permissions": [],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content-gmail.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "nicodAImus iris - Email Check"
  },
  "icons": {
    "16": "icons/iris-16.png",
    "48": "icons/iris-48.png",
    "128": "icons/iris-128.png"
  }
}
