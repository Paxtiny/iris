{
  "manifest_version": 3,
  "name": "nicodAImus iris",
  "version": "0.1.0",
  "description": "Privacy-first email phishing detection. Scores emails 0-10 for phishing risk, entirely in your browser.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://mail-attachment.googleusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content-gmail.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "nicodAImus iris - Email Check",
    "default_icon": {
      "32": "icons/nicod-mark.png",
      "48": "icons/nicod-mark.png",
      "96": "icons/nicod-mark.png"
    }
  },
  "icons": {
    "16": "icons/iris-16.png",
    "48": "icons/nicod-mark.png",
    "128": "icons/nicod-mark.png"
  }
}
